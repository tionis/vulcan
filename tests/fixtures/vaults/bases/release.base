filters:
  and:
    - 'file.ext == "md"'
properties:
  status:
    displayName: "Status"
  due:
    displayName: "Due"
views:
  - name: Release Table
    type: table
    filters:
      - 'status starts_with "b"'
      - "estimate > 2"
    order:
      - file.name
      - due
      - note_name
    groupBy:
      property: status
      direction: ASC
    formulas:
      note_name: file.name
      due_copy: due
      unsupported_calc: concat(file.name, due)
  - name: Board
    type: board
    filters:
      - "reviewed = true"
